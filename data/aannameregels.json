{
  "schema_version": "1.0",
  "purpose": "Conservatieve fallbackregels voor ontbrekende of onbruikbare invoer bij de POC-energielabeltool. Deze regels zijn alleen bedoeld voor de Gemini-gebaseerde POC-doorrekening en mogen later vervangbaar blijven bij koppeling met Vabi of Uniec.",
  "policy": {
    "principle": "conservative",
    "apply_only_when": [
      "field_missing",
      "field_unparseable",
      "field_conflicting_and_unresolved"
    ],
    "never_override_explicit_source_value": true,
    "always_record_assumptions": true,
    "always_record_uncertainties": true,
    "decrease_confidence_on_assumption": true,
    "allow_ep2_fallback_only_as_last_resort": true,
    "assumption_output_policy": "always_include_assumptions_and_uncertainties"
  },
  "status_mapping": {
    "field_missing": "missing",
    "field_unparseable": "uncertain",
    "field_conflicting_and_unresolved": "uncertain"
  },
  "rules": [
    {
      "id": "A01",
      "field": "woning.gebruiksoppervlakte_m2",
      "fallback": 120,
      "value_type": "number",
      "reason": "Conservatief referentieprofiel voor een gemiddelde bestaande grondgebonden woning wanneer gebruiksoppervlakte niet uit het Vabi-bestand kan worden gehaald.",
      "apply_when": [
        "field_missing",
        "field_unparseable"
      ],
      "uncertainty_level": "medium",
      "confidence_penalty": 0.15,
      "report_as_assumption": true
    },
    {
      "id": "A02",
      "field": "woning.bouwjaar",
      "fallback": 1975,
      "value_type": "number",
      "reason": "Conservatieve middenwaarde voor een oudere bestaande woning wanneer bouwjaar of bouwperiode ontbreekt.",
      "apply_when": [
        "field_missing",
        "field_unparseable"
      ],
      "uncertainty_level": "medium",
      "confidence_penalty": 0.10,
      "report_as_assumption": true
    },
    {
      "id": "A03",
      "field": "prestatie.current_ep2_kwh_m2",
      "fallback": 320,
      "value_type": "number",
      "reason": "Alleen gebruiken als laatste redmiddel wanneer huidige EP2 niet uit het Vabi-bestand of een betrouwbare afleiding kan worden gehaald. De waarde is conservatief en duidt op een matig tot slecht presterende woning.",
      "apply_when": [
        "field_missing",
        "field_unparseable",
        "field_conflicting_and_unresolved"
      ],
      "uncertainty_level": "high",
      "confidence_penalty": 0.30,
      "report_as_assumption": true,
      "last_resort_only": true
    },
    {
      "id": "A04",
      "field": "prestatie.current_label",
      "fallback": "E",
      "value_type": "string",
      "reason": "Alleen gebruiken als huidige EP2 ook ontbreekt of onbruikbaar is en er voor rapportage toch een conservatieve labelindicatie nodig is.",
      "apply_when": [
        "field_missing",
        "field_unparseable",
        "field_conflicting_and_unresolved"
      ],
      "uncertainty_level": "high",
      "confidence_penalty": 0.25,
      "report_as_assumption": true,
      "last_resort_only": true
    },
    {
      "id": "A05",
      "field": "installaties.verwarming.type",
      "fallback": "hr_ketel",
      "value_type": "string",
      "reason": "Meest voorkomende bestaande verwarmingssituatie in de woningvoorraad, conservatief voor POC-scenario’s.",
      "apply_when": [
        "field_missing",
        "field_unparseable"
      ],
      "uncertainty_level": "medium",
      "confidence_penalty": 0.15,
      "report_as_assumption": true
    },
    {
      "id": "A06",
      "field": "installaties.warmtapwater.type",
      "fallback": "combiketel",
      "value_type": "string",
      "reason": "Conservatieve aanname passend bij een woning met HR-ketel als bestaande basisconfiguratie.",
      "apply_when": [
        "field_missing",
        "field_unparseable"
      ],
      "uncertainty_level": "medium",
      "confidence_penalty": 0.10,
      "report_as_assumption": true
    },
    {
      "id": "A07",
      "field": "installaties.ventilatie.type",
      "fallback": "natuurlijke_ventilatie",
      "value_type": "string",
      "reason": "Conservatieve aanname wanneer geen ventilatiesysteem kan worden vastgesteld; voorkomt onterechte toekenning van WTW-voordelen.",
      "apply_when": [
        "field_missing",
        "field_unparseable"
      ],
      "uncertainty_level": "medium",
      "confidence_penalty": 0.15,
      "report_as_assumption": true
    },
    {
      "id": "A08",
      "field": "bouwdelen.dak.rc",
      "fallback": 2.0,
      "value_type": "number",
      "reason": "Onbekende dakisolatiewaarde wordt conservatief als matig geïsoleerd behandeld.",
      "apply_when": [
        "field_missing",
        "field_unparseable",
        "field_conflicting_and_unresolved"
      ],
      "uncertainty_level": "medium",
      "confidence_penalty": 0.15,
      "report_as_assumption": true
    },
    {
      "id": "A09",
      "field": "bouwdelen.gevel.rc",
      "fallback": 1.3,
      "value_type": "number",
      "reason": "Conservatieve aanname voor gevels met beperkte of onzekere na-isolatie.",
      "apply_when": [
        "field_missing",
        "field_unparseable",
        "field_conflicting_and_unresolved"
      ],
      "uncertainty_level": "medium",
      "confidence_penalty": 0.15,
      "report_as_assumption": true
    },
    {
      "id": "A10",
      "field": "bouwdelen.vloer.rc",
      "fallback": 1.5,
      "value_type": "number",
      "reason": "Conservatieve aanname voor bestaande beganegrondvloeren zonder eenduidige isolatie-informatie.",
      "apply_when": [
        "field_missing",
        "field_unparseable",
        "field_conflicting_and_unresolved"
      ],
      "uncertainty_level": "medium",
      "confidence_penalty": 0.15,
      "report_as_assumption": true
    },
    {
      "id": "A11",
      "field": "bouwdelen.glas.type",
      "fallback": "dubbel_glas",
      "value_type": "string",
      "reason": "Conservatieve middenaanname wanneer het glastype niet eenduidig uit Vabi kan worden afgeleid.",
      "apply_when": [
        "field_missing",
        "field_unparseable"
      ],
      "uncertainty_level": "medium",
      "confidence_penalty": 0.10,
      "report_as_assumption": true
    },
    {
      "id": "A12",
      "field": "bouwdelen.glas.u_waarde",
      "fallback": 2.8,
      "value_type": "number",
      "reason": "Conservatieve U-waarde passend bij ouder dubbel glas wanneer exacte beglazingsprestatie ontbreekt.",
      "apply_when": [
        "field_missing",
        "field_unparseable",
        "field_conflicting_and_unresolved"
      ],
      "uncertainty_level": "medium",
      "confidence_penalty": 0.10,
      "report_as_assumption": true
    },
    {
      "id": "A13",
      "field": "installaties.opwekking.pv_aantal",
      "fallback": 0,
      "value_type": "number",
      "reason": "Geen zonnepanelen aannemen als aanwezigheid niet expliciet uit het bronbestand blijkt.",
      "apply_when": [
        "field_missing",
        "field_unparseable"
      ],
      "uncertainty_level": "low",
      "confidence_penalty": 0.05,
      "report_as_assumption": true
    },
    {
      "id": "A14",
      "field": "installaties.opwekking.pv_vermogen_wp",
      "fallback": 0,
      "value_type": "number",
      "reason": "Geen PV-opwekking toekennen zonder expliciete broninformatie.",
      "apply_when": [
        "field_missing",
        "field_unparseable"
      ],
      "uncertainty_level": "low",
      "confidence_penalty": 0.05,
      "report_as_assumption": true
    }
  ],
  "field_priority_overrides": [
    {
      "field": "prestatie.current_ep2_kwh_m2",
      "preferred_sources": [
        "vabi_explicit_ep2",
        "validated_report_summary",
        "reliable_llm_extraction"
      ],
      "fallback_rule_id": "A03"
    },
    {
      "field": "prestatie.current_label",
      "preferred_sources": [
        "vabi_explicit_label",
        "validated_report_summary",
        "derived_from_ep2_and_labelgrenzen"
      ],
      "fallback_rule_id": "A04"
    }
  ],
  "output_requirements": {
    "include_assumptions_list": true,
    "include_uncertainties_list": true,
    "include_confidence_summary": true,
    "include_fields_with_assumptions": true
  }
}
