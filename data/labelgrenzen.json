  "input_validation": {
    "requires_numeric_ep2": true,
    "allow_null": false,
    "allow_negative_values": true,
    "null_behavior": "raise_explicit_error",
    "non_numeric_behavior": "raise_explicit_error"
  },
  "selection_helpers": {
    "supports_target_label_comparison": true,
