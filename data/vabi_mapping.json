{
  "schema_version": "1.0",
  "purpose": "Tolerante extractieregels voor het mappen van variërende Vabi-rapporten naar het interne woningmodel van de energielabel-tool. Dit bestand is bedoeld als LLM-gestuurde mappinghandleiding en niet als rigide cell- of kolommapping.",
  "methodology": {
    "primary_standard": "NTA 8800",
    "inspection_guidance": "ISSO 82.1",
    "primary_indicator": "EP2_kWh_per_m2_year"
  },
  "global_extraction_rules": {
    "mapping_mode": "llm_guided_flexible_normalization",
    "allow_missing_fields": true,
    "never_fail_on_missing_content_fields": true,
    "fail_only_on_technical_parse_errors": true,
    "always_record_uncertainties": true,
    "always_record_assumptions": true,
    "normalize_units": true,
    "normalize_decimal_separator": true,
    "prefer_explicit_source_values_over_inference": true,
    "allow_multiple_sections_with_same_semantics": true,
    "use_assumption_rules_when_needed": true
  },
  "normalization_guidance": {
    "heating_types": {
      "all-electric": "all_electric_warmtepomp",
      "all electric": "all_electric_warmtepomp",
      "all-electric warmtepomp": "all_electric_warmtepomp",
      "elektrische warmtepomp": "all_electric_warmtepomp",
      "hybride": "hybride_warmtepomp",
      "hybride warmtepomp": "hybride_warmtepomp",
      "hr-ketel": "hr_ketel",
      "hr ketel": "hr_ketel",
      "cv-ketel": "hr_ketel",
      "cv ketel": "hr_ketel",
      "warmtepomp": "warmtepomp_onbekend_type"
    },
    "ventilation_types": {
      "balans": "balansventilatie",
      "wtw": "balans_wtw",
      "balansventilatie": "balansventilatie",
      "balansventilatie met wtw": "balans_wtw",
      "mechanisch": "mechanische_ventilatie",
      "natuurlijk": "natuurlijke_ventilatie"
    },
    "boolean_values": {
      "ja": true,
      "nee": false,
      "yes": true,
      "no": false,
      "true": true,
      "false": false,
      "aanwezig": true,
      "niet aanwezig": false
    }
  },
